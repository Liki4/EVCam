<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#26000000">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="视图设置"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- 按钮区域 - 放置在最上面 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/btn_reset"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="重置"
            android:textColor="#FFFFFF"
            android:backgroundTint="#666666" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="保存"
            android:textColor="#FFFFFF"
            android:backgroundTint="#007AFF" />
    </LinearLayout>

    <!-- 左视图设置 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="左视图"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- 左视图宽度 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="宽度:"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/sb_left_width"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:max="800"
            android:progressTint="#007AFF"
            android:thumbTint="#007AFF" />

        <TextView
            android:id="@+id/tv_left_width_value"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="end" />
    </LinearLayout>

    <!-- 左视图高度 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="高度:"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/sb_left_height"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:max="600"
            android:progressTint="#007AFF"
            android:thumbTint="#007AFF" />

        <TextView
            android:id="@+id/tv_left_height_value"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="end" />
    </LinearLayout>

    <!-- 左视图X位置 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="X位置:"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/sb_left_x"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:max="1000"
            android:progressTint="#007AFF"
            android:thumbTint="#007AFF" />

        <TextView
            android:id="@+id/tv_left_x_value"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="end" />
    </LinearLayout>

    <!-- 左视图Y位置 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="Y位置:"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/sb_left_y"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:max="1000"
            android:progressTint="#007AFF"
            android:thumbTint="#007AFF" />

        <TextView
            android:id="@+id/tv_left_y_value"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="end" />
    </LinearLayout>

    <!-- 左视图旋转 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="旋转:"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/sb_left_rotation"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:max="360"
            android:progressTint="#007AFF"
            android:thumbTint="#007AFF" />

        <TextView
            android:id="@+id/tv_left_rotation_value"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="0°"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="end" />
    </LinearLayout>

    <!-- 右视图设置 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="右视图"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- 右视图宽度 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="宽度:"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/sb_right_width"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:max="800"
            android:progressTint="#007AFF"
            android:thumbTint="#007AFF" />

        <TextView
            android:id="@+id/tv_right_width_value"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="end" />
    </LinearLayout>

    <!-- 右视图高度 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="高度:"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/sb_right_height"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:max="600"
            android:progressTint="#007AFF"
            android:thumbTint="#007AFF" />

        <TextView
            android:id="@+id/tv_right_height_value"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="end" />
    </LinearLayout>

    <!-- 右视图X位置 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="X位置:"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/sb_right_x"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:max="1000"
            android:progressTint="#007AFF"
            android:thumbTint="#007AFF" />

        <TextView
            android:id="@+id/tv_right_x_value"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="end" />
    </LinearLayout>

    <!-- 右视图Y位置 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="Y位置:"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/sb_right_y"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:max="1000"
            android:progressTint="#007AFF"
            android:thumbTint="#007AFF" />

        <TextView
            android:id="@+id/tv_right_y_value"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="end" />
    </LinearLayout>

    <!-- 右视图旋转 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="旋转:"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/sb_right_rotation"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:max="360"
            android:progressTint="#007AFF"
            android:thumbTint="#007AFF" />

        <TextView
            android:id="@+id/tv_right_rotation_value"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="0°"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="end" />
    </LinearLayout>

</LinearLayout>